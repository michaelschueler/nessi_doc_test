      <memberdef kind="function" id="classintegration_1_1Integrator_a306e7e8d1bf3992f5c9a038420239bd6_1a306e7e8d1bf3992f5c9a038420239bd6" prot="public" static="no" const="yes" explicit="no" inline="yes" virt="non-virtual">
