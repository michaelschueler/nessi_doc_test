      <memberdef kind="function" id="classintegration_1_1Integrator_a521d1e7a46333f5688a83ac61a3e1f1e_1a521d1e7a46333f5688a83ac61a3e1f1e" prot="public" static="no" const="yes" explicit="no" inline="yes" virt="non-virtual">
