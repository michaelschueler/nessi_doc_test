</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>x</parametername>
</parameternamelist>
<parameterdescription>
<para>A complex square matrix into which <formula id="167">$a^{-1}$</formula> is set. Given as a pointer. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>Size of the matrix <formula id="158">$a$</formula> and <formula id="166">$x$</formula>.  </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
